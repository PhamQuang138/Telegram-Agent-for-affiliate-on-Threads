{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-daily-links",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/publish-random-links",
      "schedule": "0 * * * *"
    }
  ]
}
